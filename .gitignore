*.pyc

# RVC-сервис: свой venv, веса моделей и тестовые файлы — не часть кода
rvc_service/venv/
rvc_service/base_model/
rvc_service/models/
rvc_service/*.log
rvc_service/test_*.wav
rvc_service/test_*.mp3

# Логи
*.log

# Ваши гифки/звуки для алертов — личный контент, не часть кода
overlay/media/*
!overlay/media/README.txt

