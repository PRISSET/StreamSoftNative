# === YouTube ===
# Оставьте пустыми, если YouTube-чат не нужен.
# YOUTUBE_API_KEY — ключ из Google Cloud Console (включить "YouTube Data API v3").
# YOUTUBE_VIDEO_ID — можно вставить либо сам ID видео, либо полную ссылку на трансляцию.
YOUTUBE_API_KEY=
YOUTUBE_VIDEO_ID=

# === Twitch ===
# Оставьте пустыми, если Twitch-чат не нужен.
# TWITCH_CLIENT_ID — Client ID приложения, созданного на https://dev.twitch.tv/console/apps
# TWITCH_CHANNEL — имя канала (ник стримера), например asmongold
TWITCH_CLIENT_ID=
TWITCH_CHANNEL=
# Алерты фоллоу/сабов/рейдов/битсов через Twitch EventSub. Отключить: false
TWITCH_EVENTSUB_ENABLED=true

# === Telegram (обязательно) ===
# TELEGRAM_BOT_TOKEN — токен бота от @BotFather
# TELEGRAM_CHAT_ID — id чата/группы, куда слать сообщения
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Управление командами /mute, /skip, /volume прямо в Telegram. Отключить: false
TELEGRAM_CONTROL_ENABLED=true

# === TTS (edge-tts) ===
# Список голосов: edge-tts --list-voices
# TTS_VOICE — голос по умолчанию (для текста не на русском и не на английском)
# TTS_VOICE_RU / TTS_VOICE_EN — голоса для авто-определения языка сообщения
TTS_VOICE=ru-RU-DmitryNeural
TTS_VOICE_RU=ru-RU-DmitryNeural
TTS_VOICE_EN=en-US-GuyNeural
TTS_RATE=+0%
TTS_VOLUME=100
TTS_SAY_AUTHOR=true
TTS_MAX_CHARS=200

# === Оверлей для OBS (Browser Source) ===
OVERLAY_ENABLED=true
OVERLAY_PORT=8099
